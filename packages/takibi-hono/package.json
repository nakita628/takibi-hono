{
  "name": "takibi-hono",
  "version": "0.3.0",
  "description": "Takibi Hono is a code generator from OpenAPI to hono",
  "keywords": [
    "hono",
    "openapi"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nakita628/takibi-hono.git"
  },
  "bin": {
    "takibi-hono": "dist/index.js"
  },
  "type": "module",
  "exports": {
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.js"
    },
    "./vite-plugin": {
      "types": "./dist/vite-plugin/index.d.ts",
      "import": "./dist/vite-plugin/index.js"
    }
  },
  "scripts": {
    "build": "tsdown"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@typespec/compiler": "^1.12.0",
    "@typespec/openapi3": "^1.12.0",
    "hono-takibi": "0.9.9997",
    "oxfmt": "^0.51.0",
    "schema-to-library": "^0.3.3",
    "ts-morph": "^28.0.0",
    "typescript": "^6.0.3",
    "valibot": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@typespec/http": "^1.12.0",
    "@typespec/rest": "^0.82.0",
    "@typespec/versioning": "^0.82.0",
    "tsdown": "^0.22.0",
    "vite": "^8.0.14"
  }
}
