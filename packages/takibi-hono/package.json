{
  "name": "takibi-hono",
  "version": "0.0.4",
  "description": "Takibi Hono is a code generator from OpenAPI to hono",
  "keywords": [
    "hono",
    "openapi"
  ],
  "bin": {
    "takibi-hono": "dist/index.js"
  },
  "type": "module",
  "exports": {
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.js"
    },
    "./vite-plugin": {
      "types": "./dist/vite-plugin/index.d.ts",
      "import": "./dist/vite-plugin/index.js"
    }
  },
  "scripts": {
    "deps": "rm -rf node_modules && pnpm install",
    "build": "tsdown",
    "release": "pnpm build && pnpm publish"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@typespec/compiler": "^1.11.0",
    "@typespec/openapi3": "^1.11.0",
    "oxfmt": "^0.46.0",
    "schema-to-library": "0.1.0",
    "ts-morph": "^28.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typespec/http": "^1.11.0",
    "@typespec/rest": "^0.81.0",
    "@typespec/versioning": "^0.81.0",
    "tsdown": "^0.21.10",
    "vite": "^8.0.10"
  }
}
